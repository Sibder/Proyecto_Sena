@page "/profile"
@layout Sena_app.Components.Layout.MainLayout
@using Sena_app.Services
@using Sena_app.Models
@inject AuthService AuthService
@inject TaskService TaskService
@inject NavigationManager Navigation

<PageTitle>Mi Perfil — Gestor</PageTitle>

<div class="profile-layout">

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <aside class="sidebar">
        <a href="/home" class="sidebar-brand">
            <span class="brand-icon">
                <svg fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M9 2h6a1 1 0 011 1v1H8V3a1 1 0 011-1z" />
                    <path d="M5 4h14a2 2 0 012 2v13a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" />
                    <path d="M9 12h6M9 16h4" />
                </svg>
            </span>
            <span>GESTOR DE TAREAS</span>
        </a>


        <nav class="sidebar-nav">
            <div class="nav-label">General</div>
            <a href="/home" class="nav-item">
                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                Panel de tareas
            </a>
            <a href="#" class="nav-item">
                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
                Calendario
            </a>
            <a href="#" class="nav-item">
                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                Estadísticas
            </a>
            <a href="#" class="nav-item">
                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" /></svg>
                Notificaciones
                <span class="badge">3</span>
            </a>

            <div class="nav-label" style="margin-top:8px;">Cuenta</div>
            <a href="/profile" class="nav-item active">
                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                Mi perfil
            </a>
            <a href="#" class="nav-item" @onclick="HandleLogout">
                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                Cerrar sesión
            </a>
        </nav>
    </aside>

    <!-- ═══════════ CONTENIDO ═══════════ -->
    <div class="content-area">

        <!-- TOPBAR -->
        <header class="topbar">
            <div class="topbar-left"><h2>Mi Perfil</h2></div>
            <div class="topbar-right">
                <button class="btn-ghost" @onclick='() => Navigation.NavigateTo("/")'>← Volver al dashboard</button>
                <div class="user-chip">
                    <div class="user-avatar">@AuthService.CurrentUser?.Initials</div>
                    @AuthService.CurrentUser?.FullName
                </div>
            </div>
        </header>

        <!-- MAIN -->
        <main class="main-content">

            <!-- Hero del perfil -->
            <div class="profile-hero">
                <div class="avatar-wrap">
                    <div class="avatar">@AuthService.CurrentUser?.Initials</div>
                    <div class="avatar-edit-btn">
                        <svg fill="none" stroke-width="2.5" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                    </div>
                </div>
                <div class="profile-info">
                    <h1>@AuthService.CurrentUser?.FullName</h1>
                    <p>@AuthService.CurrentUser?.Email</p>
                </div>
                <div class="profile-stats">
                    <div class="stat-card blue"><strong>@TaskService.CountDone(AuthService.CurrentUser?.Id ?? 0)</strong><span>Hechas</span></div>
                    <div class="stat-card yellow"><strong>@TaskService.CountPending(AuthService.CurrentUser?.Id ?? 0)</strong><span>Pendientes</span></div>
                    <div class="stat-card green"><strong>4</strong><span>Categorías</span></div>
                </div>
            </div>

            <!-- Tabs -->
            <div class="tabs">
                <button class="tab @(activeTab == "info" ? "active" : "")" @onclick='() => activeTab = "info"'>Información personal</button>
                <button class="tab @(activeTab == "security" ? "active" : "")" @onclick='() => activeTab = "security"'>Seguridad</button>
                <button class="tab @(activeTab == "notifications" ? "active" : "")" @onclick='() => activeTab = "notifications"'>Notificaciones</button>
            </div>

            <!-- Panel: Info personal -->
            @if (activeTab == "info")
            {
                <div class="tab-panel">
                    <div class="section-card">
                        <h2><span class="dot blue"></span>Datos personales</h2>
                        <div class="grid-2">
                            <div class="field">
                                <label>Nombre</label>
                                <div class="input-wrap">
                                    <input type="text" @bind="firstName" />
                                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                </div>
                            </div>
                            <div class="field">
                                <label>Apellido</label>
                                <div class="input-wrap">
                                    <input type="text" @bind="lastName" />
                                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                </div>
                            </div>
                        </div>
                        <div class="field">
                            <label>Correo electrónico</label>
                            <div class="input-wrap">
                                <input type="email" @bind="email" />
                                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                            </div>
                        </div>
                        <div class="field">
                            <label>Teléfono</label>
                            <div class="input-wrap">
                                <input type="tel" @bind="phone" placeholder="Ej: +57 300 000 0000" />
                                <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24">
                                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07
                                    19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18
                                    2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81
                                    a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27
                                    a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
                                </svg>
                            </div>
                        </div>
                        <div class="field">
                            <label>Biografía</label>
                            <textarea @bind="bio" placeholder="Cuéntanos algo sobre ti..."></textarea>
                        </div>
                    </div>

                    <div class="section-card">
                        <h2><span class="dot green"></span>Preferencias de la app</h2>
                        <div class="grid-2">
                            <div class="field"><label>Idioma</label><select><option>Español</option><option>English</option><option>Português</option></select></div>
                            <div class="field"><label>Zona horaria</label><select><option>GMT-5 (Bogotá)</option><option>GMT-6 (México)</option><option>GMT-3 (Buenos Aires)</option></select></div>
                            <div class="field"><label>Primer día de la semana</label><select><option>Lunes</option><option>Domingo</option></select></div>
                            <div class="field"><label>Formato de hora</label><select><option>12 horas (AM/PM)</option><option>24 horas</option></select></div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(errorMsg))
                    {
                        <p style="color:#e53935; font-size:13px; margin-bottom:8px;">@errorMsg</p>
                    }
                    <div class="form-actions">
                        <button class="btn-cancel" @onclick="ResetForm">Cancelar</button>
                        <button class="btn-primary" @onclick="SaveChanges">Guardar cambios</button>
                    </div>
                </div>
            }

            <!-- Panel: Seguridad -->
            @if (activeTab == "security")
            {
                <div class="tab-panel">
                    <div class="section-card">
                        <h2>
                            <span class="dot blue"></span>
                            @(AuthService.CurrentUser?.IsGoogleAccount == true ? "Establecer contraseña" : "Cambiar contraseña")
                        </h2>

                        @if (AuthService.CurrentUser?.IsGoogleAccount != true)
                        {
                            <div class="field">
                                <label>Contraseña actual</label>
                                <div class="input-wrap">
                                    <input type="password" placeholder="••••••••" @bind="currentPassword" />
                                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
                                </div>
                            </div>
                        }

                        <div class="grid-2">
                            <div class="field">
                                <label>Nueva contraseña</label>
                                <div class="input-wrap">
                                    <input type="password" placeholder="Mínimo 8 caracteres" @bind="newPassword" />
                                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
                                </div>
                            </div>
                            <div class="field">
                                <label>Confirmar contraseña</label>
                                <div class="input-wrap">
                                    <input type="password" placeholder="Repite la contraseña" @bind="confirmPassword" />
                                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMsg))
                        {
                            <p style="color:#e53935; font-size:13px; margin-bottom:8px;">@errorMsg</p>
                        }

                        <div class="form-actions">
                            @if (AuthService.CurrentUser?.IsGoogleAccount == true)
                            {
                                <button class="btn-primary" @onclick="EstablecerContrasena">Establecer contraseña</button>
                            }
                            else
                            {
                                <button class="btn-primary" @onclick="UpdatePassword">Actualizar</button>
                            }
                        </div>
                    </div>

                    <div class="section-card">
                        <h2><span class="dot blue"></span>Google Calendar</h2>
                        @if (calendarConectado)
                        {
                            <div class="toggle-row">
                                <div class="toggle-info">
                                    <h3>✅ Cuenta conectada</h3>
                                    <p>Tus tareas se sincronizan automáticamente con Google Calendar.</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="toggle-row">
                                <div class="toggle-info">
                                    <h3>Conectar Google Calendar</h3>
                                    <p>Sincroniza tus tareas con tu calendario de Google.</p>
                                </div>
                                <button class="btn-primary" @onclick="ConectarCalendar">Conectar</button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(calendarMsg))
                        {
                            <p style="font-size:13px; margin-top:8px; color: @(calendarError ? "#e53935" : "#26a69a")">
                                @calendarMsg
                            </p>
                        }
                        <h2><span class="dot yellow"></span>Sesiones activas</h2>
                        <div class="toggle-row">
                            <div class="toggle-info"><h3>Chrome · Windows</h3><p>Bogotá, Colombia · Activo ahora</p></div>
                            <span class="session-badge">● Esta sesión</span>
                        </div>
                    </div>

                    <div class="danger-zone">
                        <h2>⚠ Zona de peligro</h2>
                        <div class="danger-row"><p>Exportar todos tus datos en formato JSON.</p><button class="btn-danger">Exportar datos</button></div>
                        <div class="danger-row"><p>Eliminar permanentemente tu cuenta y todas tus tareas.</p><button class="btn-danger">Eliminar cuenta</button></div>
                    </div>
                </div>
            }

            <!-- Panel: Notificaciones -->
            @if (activeTab == "notifications")
            {
                <div class="tab-panel">
                    <div class="section-card">
                        <h2><span class="dot green"></span>Recordatorios</h2>
                        <div class="toggle-row">
                            <div class="toggle-info"><h3>Recordatorios de tareas</h3><p>Alertas antes del vencimiento de una tarea.</p></div>
                            <label class="switch"><input type="checkbox" checked /><span class="switch-track"></span></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-info"><h3>Resumen diario</h3><p>Un resumen de tus tareas cada mañana.</p></div>
                            <label class="switch"><input type="checkbox" checked /><span class="switch-track"></span></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-info"><h3>Tareas vencidas</h3><p>Alerta cuando una tarea pase su fecha límite.</p></div>
                            <label class="switch"><input type="checkbox" /><span class="switch-track"></span></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-info"><h3>Correo electrónico</h3><p>Resúmenes y alertas importantes por email.</p></div>
                            <label class="switch"><input type="checkbox" /><span class="switch-track"></span></label>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="btn-cancel">Cancelar</button>
                        <button class="btn-primary" @onclick="SaveChanges">Guardar preferencias</button>
                    </div>
                </div>
            }

            <!-- Toast -->
            @if (showToast)
            {
                <div class="toast show">
                    <svg fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    @toastMsg
                </div>
            }

        </main>
    </div>
</div>

@code {
    private string activeTab = "info";

    private string firstName = string.Empty;
    private string lastName = string.Empty;
    private string email = string.Empty;
    private string bio = string.Empty;
    private string phone = string.Empty;
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMsg = string.Empty;

    private bool showToast = false;
    private string toastMsg = "Cambios guardados correctamente";

    [Inject] private GoogleCalendarService GoogleCalendarService { get; set; } = default!;

    private bool calendarConectado = false;
    private bool calendarError = false;
    private string calendarMsg = string.Empty;

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/");
            return;
        }
        firstName = AuthService.CurrentUser?.FirstName ?? string.Empty;
        lastName = AuthService.CurrentUser?.LastName ?? string.Empty;
        email = AuthService.CurrentUser?.Email ?? string.Empty;
        phone = AuthService.CurrentUser?.Phone ?? string.Empty;
    }

    private void SaveChanges()
    {
        errorMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName))
        {
            errorMsg = "El nombre y apellido son obligatorios.";
            return;
        }

        if (string.IsNullOrWhiteSpace(email))
        {
            errorMsg = "El correo es obligatorio.";
            return;
        }

        bool ok = AuthService.UpdateProfile(firstName, lastName, email, phone);

        if (!ok)
        {
            errorMsg = "El correo ya está en uso por otro usuario.";
            return;
        }

        ShowToast("Cambios guardados correctamente");
    }

    private void UpdatePassword()
    {
        errorMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(currentPassword) ||
            string.IsNullOrWhiteSpace(newPassword) ||
            string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMsg = "Completá todos los campos de contraseña.";
            return;
        }

        if (AuthService.CurrentUser?.Password != currentPassword)
        {
            errorMsg = "La contraseña actual no es correcta.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMsg = "Las contraseñas nuevas no coinciden.";
            return;
        }

        if (newPassword.Length < 8)
        {
            errorMsg = "La nueva contraseña debe tener al menos 8 caracteres.";
            return;
        }

        AuthService.UpdatePassword(AuthService.CurrentUser?.Email, newPassword);
        currentPassword = string.Empty;
        newPassword = string.Empty;
        confirmPassword = string.Empty;
        ShowToast("Contraseña actualizada correctamente");
    }

    private void ResetForm()
    {
        firstName = AuthService.CurrentUser?.FirstName ?? string.Empty;
        lastName = AuthService.CurrentUser?.LastName ?? string.Empty;
        email = AuthService.CurrentUser?.Email ?? string.Empty;
        phone = AuthService.CurrentUser?.Phone ?? string.Empty;
        errorMsg = string.Empty;
    }

    private void ShowToast(string msg)
    {
        toastMsg = msg;
        showToast = true;
        StateHasChanged();
        Task.Delay(3000).ContinueWith(_ =>
        {
            showToast = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthService.CurrentUser is not null)
        {
            calendarConectado = await GoogleCalendarService
                                      .IsConnectedAsync(AuthService.CurrentUser.Id);

            // Leer parámetros de retorno del OAuth
            var uri = new Uri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

            if (query["calendarConnected"] == "true")
            {
                calendarConectado = true;
                calendarMsg = "Google Calendar conectado correctamente.";
                calendarError = false;
            }
            else if (!string.IsNullOrEmpty(query["calendarError"]))
            {
                calendarMsg = "Error al conectar Google Calendar. Intentá de nuevo.";
                calendarError = true;
            }

            StateHasChanged();
        }
    }

    private void ConectarCalendar()
    {
        if (AuthService.CurrentUser is null) return;
        var url = GoogleCalendarService.GetAuthorizationUrl(
                      AuthService.CurrentUser.Id.ToString());
        Navigation.NavigateTo(url, forceLoad: true);
    }

    private void EstablecerContrasena()
    {
        errorMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(newPassword) ||
            string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMsg = "Completá todos los campos.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMsg = "Las contraseñas no coinciden.";
            return;
        }

        if (newPassword.Length < 8)
        {
            errorMsg = "La contraseña debe tener al menos 8 caracteres.";
            return;
        }

        AuthService.UpdatePassword(AuthService.CurrentUser?.Email, newPassword);
        newPassword = string.Empty;
        confirmPassword = string.Empty;
        ShowToast("Contraseña establecida correctamente");
    }
}