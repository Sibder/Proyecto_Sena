@page "/"
@using Sena_app.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>GESTOR — Iniciar sesión</PageTitle>

<div class="login-layout">
    <aside class="side-panel">
        <a href="/" class="brand">
            <span class="brand-icon">
                <svg fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M9 2h6a1 1 0 011 1v1H8V3a1 1 0 011-1z" />
                    <path d="M5 4h14a2 2 0 012 2v13a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z" />
                    <path d="M9 12h6M9 16h4" />
                </svg>
            </span>
            <span>GESTOR DE TAREAS</span>
        </a>

        <div class="side-content">
            <h2>Organiza tu día,<br />sin esfuerzo.</h2>
            <p>Accede a tus tareas, recordatorios y categorías en un solo lugar.</p>
            <div class="stats-row">
                <div class="stat-mini b"><span>Tareas hoy</span></div>
                <div class="stat-mini g"><span>Hechas</span></div>
                <div class="stat-mini y"><span>Pendientes</span></div>
            </div>
        </div>

        <ul class="features-list">
            <li>Recordatorios por hora</li>
            <li>Categorías personalizables</li>
            <li>Prioridades y fechas límite</li>
        </ul>
    </aside>

    <main class="form-panel">
        <div class="form-card">
            <div class="form-header">
                <h1>Bienvenido de vuelta</h1>
                <p>¿No tienes cuenta? <a href="/registro">Regístrate gratis</a></p>
            </div>

            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="error-msg">@errorMsg</div>
            }

            <div class="field">
                <label>Correo electrónico</label>
                <div class="input-wrap">
                    <input type="email" placeholder="tú@correo.com" @bind="email" @bind:event="oninput" autocomplete="email" />
                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                        <polyline points="22,6 12,13 2,6" />
                    </svg>
                </div>
            </div>

            <div class="field">
                <label>Contraseña</label>
                <div class="input-wrap">
                    <input type="password" placeholder="••••••••" @bind="password" @bind:event="oninput" autocomplete="current-password" />
                    <svg fill="none" stroke-width="1.8" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2" />
                        <path d="M7 11V7a5 5 0 0110 0v4" />
                    </svg>
                </div>
            </div>

            <div class="field-row">
                <label><input type="checkbox" @bind="rememberMe" /> Recordarme</label>
                <a href="/recuperar" class="forgot-link">¿Olvidaste tu contraseña?</a>
            </div>

            <button class="btn-primary" @onclick="HandleLogin">Iniciar sesión</button>
           
            <div class="divider"><span>o continúa con</span></div>

            <button class="btn-social" type="button"
                    @onclick='() => Navigation.NavigateTo("/auth/google/signin", forceLoad: true)'>
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" />
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
                </svg>
                Continuar con Google
            </button>
        </div>
    </main>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool rememberMe = false;
    private string errorMsg = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.RestoreSessionAsync();
            if (AuthService.IsAuthenticated)
            {
                Navigation.NavigateTo("/home", replace: true);
                return;
            }

            // Manejar retorno de Google Sign-In
            var uri = new Uri(Navigation.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var googleLoginId = query["googleLogin"];

            if (!string.IsNullOrEmpty(googleLoginId) &&
                int.TryParse(googleLoginId, out int userId))
            {
                bool ok = await AuthService.LoginByIdAsync(userId);
                if (ok)
                {
                    Navigation.NavigateTo("/home", replace: true);
                    return;
                }
            }

            if (query["googleError"] is not null)
                errorMsg = "No se pudo iniciar sesión con Google. Intentá de nuevo.";

            StateHasChanged();
        }
    }

    private async Task HandleLogin()
    {
        errorMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMsg = "Completa todos los campos.";
            return;
        }

        bool ok = await AuthService.LoginAsync(email, password);

        if (!ok)
        {
            errorMsg = "Correo o contraseña incorrectos.";
            return;
        }

        Navigation.NavigateTo("/home", replace: true);
    }
}
